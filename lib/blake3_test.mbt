///|
fn blake3_hex(data : Bytes, n : Int) -> String {
  bytes_to_hex(blake3_xof(data, n))
}

///|
test "BLAKE3 vector 0" {
  assert_true(
    blake3_hex(hex_to_bytes(""), 32) ==
    "af1349b9f5f9a1a6a0404dea36dcc9499bcb25c9adc112b7cc9a93cae41f3262",
  )
}

///|
test "BLAKE3 vector 1" {
  assert_true(
    blake3_hex(hex_to_bytes("616263"), 32) ==
    "6437b3ac38465133ffb63b75273a8db548c558465d79db03fd359c6cd5bd9d85",
  )
}

///|
test "BLAKE3 vector 2" {
  assert_true(
    blake3_hex(
      hex_to_bytes(
        "000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f202122232425262728292a2b2c2d2e2f303132333435363738393a3b3c3d3e3f",
      ),
      32,
    ) ==
    "4eed7141ea4a5cd4b788606bd23f46e212af9cacebacdc7d1f4c6dc7f2511b98",
  )
}

///|
test "BLAKE3 vector 3" {
  assert_true(
    blake3_hex(
      hex_to_bytes(
        "",
      ),
      32,
    ) ==
    "f9c991a91ce818ab00f3bf22cef993a2f8d9ab0206f2b9efcef063bb19046966",
  )
}

///|
test "BLAKE3 vector 4" {
  assert_true(
    blake3_hex(
      hex_to_bytes(
        "",
      ),
      32,
    ) ==
    "882179b8dbccd285cda241d968cfcccb3156c5edac2fa3761bb6eda7ff8cb172",
  )
}

///|
test "BLAKE3 vector 5" {
  assert_true(
    blake3_hex(hex_to_bytes("616263"), 64) ==
    "6437b3ac38465133ffb63b75273a8db548c558465d79db03fd359c6cd5bd9d851fb250ae7393f5d02813b65d521a0d492d9ba09cf7ce7f4cffd900f23374bf0b",
  )
}

///|
test "BLAKE3 vector 6" {
  assert_true(
    blake3_hex(hex_to_bytes(""), 16) == "af1349b9f5f9a1a6a0404dea36dcc949",
  )
}

///|
test "BLAKE3 vector 7" {
  assert_true(
    blake3_hex(
      hex_to_bytes(
        "000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f202122232425262728292a2b2c2d2e2f303132333435363738393a3b3c3d3e3f404142434445464748494a4b4c4d4e4f505152535455565758595a5b5c5d5e5f60616263",
      ),
      200,
    ) ==
    "",
  )
}
