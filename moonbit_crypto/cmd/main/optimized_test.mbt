  0x2de92c6fU, 0x4a7484aaU, 0x5cb0a9dcU, 0x76f988daU,
  0x983e5152U, 0xa831c66dU, 0xb00327c8U, 0xbf597fc7U,
  0xc6e00bf3U, 0xd5a79147U, 0x06ca6351U, 0x14292967U,
  0x27b70a85U, 0x2e1b2138U, 0x4d2c6dfcU, 0x53380d13U,
  0x650a7354U, 0x766a0abbU, 0x81c2c92eU, 0x92722c85U,
  0xa2bfe8a1U, 0xa81a664bU, 0xc24b8b70U, 0xc76c51a3U,
  0xd192e819U, 0xd6990624U, 0xf40e3585U, 0x106aa070U,
  0x19a4c116U, 0x1e376c08U, 0x2748774cU, 0x34b0bcb5U,
  0x391c0cb3U, 0x4ed8aa4aU, 0x5b9cca4fU, 0x682e6ff3U,
  0x748f82eeU, 0x78a5636fU, 0x84c87814U, 0x8cc70208U,
  0x90befffaU, 0xa4506cebU, 0xbef9a3f7U, 0xc67178f2U
]

// 预计算的初始哈希值
const H0: Array[UInt] = [
  0x6a09e667U, 0xbb67ae85U, 0x3c6ef372U, 0xa54ff53aU,
  0x510e527fU, 0x9b05688cU, 0x1f83d9abU, 0x5be0cd19U
]

// 内联优化：旋转右移
fn rotr(x: UInt, n: Int) -> UInt {
  (x >> n) | (x << (32 - n))
}

// 内联优化：压缩函数sigma0
fn sig0(x: UInt) -> UInt {
  rotr(x, 7) ^ rotr(x, 18) ^ (x >> 3)
}

// 内联优化：压缩函数sigma1
fn sig1(x: UInt) -> UInt {
  rotr(x, 17) ^ rotr(x, 19) ^ (x >> 10)
}

// 优化版本：从字节数组批量读取32位整数
fn read_u32_be_fast(data: Bytes, offset: Int) -> UInt {
  (data[offset].to_uint() << 24) |
  (data[offset + 1].to_uint() << 16) |
  (data[offset + 2].to_uint() << 8) |
  data[offset + 3].to_uint()
}

// 优化版本：批量写入32位整数到字节数组
fn write_u32_be_fast(val: UInt, result: Array[Byte], offset: Int) -> Unit {
  result[offset] = ((val >> 24) & 0xFFU).to_byte()
  result[offset + 1] = ((val >> 16) & 0xFFU).to_byte()
  result[offset + 2] = ((val >> 8) & 0xFFU).to_byte()
  result[offset + 3] = (val & 0xFFU).to_byte()
}

// 优化版本：SHA-256压缩函数（使用预计算常量）
fn process_block_fast(state: Array[UInt], block: Array[UInt], w: Array[UInt]) -> Unit {
  // 展开前16轮
  for i in 0..=15 {
    w[i] = block[i]
  }
  
  // 预计算前16轮的w值
  for i in 16..=63 {
    w[i] = sig1(w[i - 2]) + w[i - 7] + sig0(w[i - 15]) + w[i - 16]
  }
  
  // 使用局部变量减少数组访问
  let mut a = state[0]
  let mut b = state[1]
  let mut c = state[2]
  let mut d = state[3]
  let mut e = state[4]
  let mut f = state[5]
  let mut g = state[6]
  let mut h = state[7]
  
  // 主循环
  for i in 0..=63 {
    let t1 = h + rotr(e, 6) ^ rotr(e, 11) ^ rotr(e, 25) + (e & f) ^ ((0xFFFFFFFFU ^ e) & g) + K[i] + w[i]
    let t2 = rotr(a, 2) ^ rotr(a, 13) ^ rotr(a, 22) + (a & b) ^ (a & c) ^ (b & c)
    h = g
    g = f
    f = e
    e = d + t1
    d = c
    c = b
    b = a
    a = t1 + t2
  }
  
  state[0] = state[0] + a
  state[1] = state[1] + b
  state[2] = state[2] + c
  state[3] = state[3] + d
  state[4] = state[4] + e
  state[5] = state[5] + f
  state[6] = state[6] + g
  state[7] = state[7] + h
}

// 优化版本：消息填充
fn pad_message_fast(data: Bytes) -> Array[Byte] {
  let original_len = data.length()
  let bit_len = original_len * 8
  let pad_len = 64 - ((original_len + 9) % 64)
  let final_len = original_len + 9 + pad_len
  
  let padded = Array::make(final_len, b'\x00')
  
  // 复制原始数据
  for i in 0..<original_len {
    padded[i] = data[i]
  }
  
  // 添加填充位
  padded[original_len] = b'\x80'
  
  // 添加长度（大端序）
  let bit_len_u64 = bit_len.to_uint64()
  let base = original_len + 1 + pad_len
  padded[base] = ((bit_len_u64 >> 56) & 0xFFUL).to_byte()
  padded[base + 1] = ((bit_len_u64 >> 48) & 0xFFUL).to_byte()
  padded[base + 2] = ((bit_len_u64 >> 40) & 0xFFUL).to_byte()
  padded[base + 3] = ((bit_len_u64 >> 32) & 0xFFUL).to_byte()
  padded[base + 4] = ((bit_len_u64 >> 24) & 0xFFUL).to_byte()
  padded[base + 5] = ((bit_len_u64 >> 16) & 0xFFUL).to_byte()
  padded[base + 6] = ((bit_len_u64 >> 8) & 0xFFUL).to_byte()
  padded[base + 7] = (bit_len_u64 & 0xFFUL).to_byte()
  
  padded
}

// 优化版本：SHA-256主函数
fn sha256_fast(data: Bytes) -> Bytes {
  // 使用预计算的初始值
  let state = [H0[0], H0[1], H0[2], H0[3], H0[4], H0[5], H0[6], H0[7]]
  
  let padded = pad_message_fast(data)
  let num_blocks = padded.length() / 64
  
  // 预分配工作数组（避免循环内分配）
  let w = Array::make(64, 0U)
  
  // 批量处理所有块
  for i in 0..<num_blocks {
    let offset = i * 64
    let block = [
      read_u32_be_fast(padded, offset),
      read_u32_be_fast(padded, offset + 4),
      read_u32_be_fast(padded, offset + 8),
      read_u32_be_fast(padded, offset + 12),
      read_u32_be_fast(padded, offset + 16),
      read_u32_be_fast(padded, offset + 20),
      read_u32_be_fast(padded, offset + 24),
      read_u32_be_fast(padded, offset + 28),
      read_u32_be_fast(padded, offset + 32),
      read_u32_be_fast(padded, offset + 36),
      read_u32_be_fast(padded, offset + 40),
      read_u32_be_fast(padded, offset + 44),
      read_u32_be_fast(padded, offset + 48),
      read_u32_be_fast(padded, offset + 52),
      read_u32_be_fast(padded, offset + 56),
      read_u32_be_fast(padded, offset + 60)
    ]
    process_block_fast(state, block, w)
  }
  
  // 直接写入结果
  let result = Array::make(32, b'\x00')
  write_u32_be_fast(state[0], result, 0)
  write_u32_be_fast(state[1], result, 4)
  write_u32_be_fast(state[2], result, 8)
  write_u32_be_fast(state[3], result, 12)
  write_u32_be_fast(state[4], result, 16)
  write_u32_be_fast(state[5], result, 20)
  write_u32_be_fast(state[6], result, 24)
  write_u32_be_fast(state[7], result, 28)
  
  Bytes::from_array(result[:])
}

