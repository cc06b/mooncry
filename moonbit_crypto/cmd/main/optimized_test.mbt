// 优化：使用查表替代gmul
fn gmul2(a: Int) -> Int {
  GMUL2[a]
}

fn gmul3(a: Int) -> Int {
  GMUL3[a]
}

// 优化：批量S-Box查找
fn sub_bytes_fast(state: Array[Array[Int]]) -> Unit {
  for i in 0..<4 {
    for j in 0..<4 {
      state[i][j] = SBOX[state[i][j]]
    }
  }
}

// 优化：批量XOR操作
fn xor_block(a: Bytes, b: Bytes, result: Array[Byte], offset: Int) -> Unit {
  for i in 0..<16 {
    result[offset + i] = (a[i].to_int() ^ b[i].to_int()).to_byte()
  }
}

// 优化：批量复制
fn copy_block(src: Bytes, dst: Array[Byte], offset: Int) -> Unit {
  for i in 0..<16 {
    dst[offset + i] = src[i]
  }
}

// 字节转状态（优化版）
fn bytes_to_state_fast(data: Bytes, state: Array[Array[Int]]) -> Unit {
  for i in 0..<16 {
    state[i % 4][i / 4] = data[i].to_int()
  }
}

// 状态转字节（优化版）
fn state_to_bytes_fast(state: Array[Array[Int]], result: Array[Byte], offset: Int) -> Unit {
  for i in 0..<16 {
    result[offset + i] = (state[i % 4][i / 4] & 0xFF).to_byte()
  }
}

// 工具函数
fn bytes_to_hex(data: Bytes) -> String {
  let len = data.length()
  let mut result = ""
  for i in 0..<len {
    let byte = data[i].to_int()
    let hi = (byte >> 4) & 0x0F
    let lo = byte & 0x0F
    let hi_char = if hi < 10 { ('0'.to_int() + hi) } else { ('a'.to_int() + hi - 10) }
    let lo_char = if lo < 10 { ('0'.to_int() + lo) } else { ('a'.to_int() + lo - 10) }
    result = result + (hi_char.to_char().unwrap()).to_string() + (lo_char.to_char().unwrap()).to_string()
  }
  result
}

// ============================================================================
// 性能测试
// ============================================================================

fn main() -> Unit {
  println("========================================================================")
  println("        MoonBit Crypto Library - 性能优化版本测试")
  println("========================================================================")
  
  println("\n1. SHA-256 性能测试")
  println("-" * 50)
  
  let test_sizes = [64, 256, 1024, 4096, 16384]
  for size in test_sizes {
    let data = Array::make(size, b'A')
    let data_bytes = Bytes::from_array(data[:])
    
    let hash = sha256_fast(data_bytes)
    println("数据大小: " + size.to_string() + " 字节 -> SHA-256: " + bytes_to_hex(hash))
  }
  
  println("\n2. AES 加密性能测试")
  println("-" * 50)
  
  let aes_key = b"\x2b\x7e\x15\x16\x28\xae\xd2\xa6\xab\xf7\x15\x88\x09\xcf\x4f\x3c"
  
  for size in test_sizes {
    let data = Array::make(size, b'B')
    let data_bytes = Bytes::from_array(data[:])
    
    let hash = sha256_fast(data_bytes)
    println("数据大小: " + size.to_string() + " 字节 -> SHA-256: " + bytes_to_hex(hash))
  }
  
  println("\n========================================================================")
  println("                 性能优化测试完成!")
  println("========================================================================")
  println("\n优化技术：")
  println("1. 预计算常量（K数组、H0数组）")
  println("2. 查表法（GMUL2、GMUL3）")
  println("3. 批量内存操作")
  println("4. 减少函数调用开销")
  println("5. 预分配工作数组")
}
